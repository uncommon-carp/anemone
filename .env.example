# anemone environment variables
# Copy to .env and adjust. Defaults shown below are the VULNERABLE state.
# See README.md for the full vulnerability inventory.

# Server port
PORT=3000

# ── Security headers ───────────────────────────────────────────────────────────
# false → missing HSTS, X-Content-Type-Options, Referrer-Policy, CSP
# (findings: headers.missing_hsts, missing_xcto, missing_referrer_policy)
ADD_SECURITY_HEADERS=false

# ── CORS ───────────────────────────────────────────────────────────────────────
# false → reflects any Origin + sets Allow-Credentials: true
# (finding: cors.origin_reflection)
CORS_STRICT=false

# true → Allow-Origin: * with Allow-Credentials: true (spec-invalid combination)
# (finding: cors.wildcard_with_credentials)
CORS_WILDCARD=false

# ── Exposed endpoints ──────────────────────────────────────────────────────────
# true → /swagger and /openapi.json publicly reachable
# (finding: inventory.sensitive_endpoint_exposed)
EXPOSE_SWAGGER=true

# true → /api/v1/ returns 200 even though v2 is declared current in OpenAPI spec
# (finding: inventory.stale_version_responding)
LEGACY_API=true

# true → POST /graphql answers __schema introspection queries
# (findings: inventory.graphql_introspection_enabled, inventory.sensitive_endpoint_exposed)
GRAPHQL_INTROSPECTION=true

# ── JWT ────────────────────────────────────────────────────────────────────────
# "none" → tokens issued with alg:none and no signature (finding: jwt.alg_none)
# Any other value (e.g. HS256) → tokens issued with a hardcoded stub signature "c2ln"
# — still trivially forgeable (finding: jwt.weak_signature)
JWT_ALG=none

# Token lifetime in seconds. Default ~27.7 h; threshold for jwt.long_ttl is 24 h (86400 s).
JWT_TTL_SECONDS=99999

# true → issued tokens omit the exp claim entirely (finding: jwt.missing_exp)
JWT_MISSING_EXP=false

# ── Auth enforcement ───────────────────────────────────────────────────────────
# false → /api/v2/users accepts unauthenticated requests (finding: auth.unenforced)
# true  → enforces Bearer token but returns 401 without WWW-Authenticate header
#          (finding: auth.401_missing_www_authenticate)
AUTH_REQUIRED=false

# ── Injection ──────────────────────────────────────────────────────────────────
# true → SQL error strings reflected in 500 responses to /api/v2/search
# (finding: injection.sql_error_disclosure)
VULNERABLE_SQL=true

# true → {{expr}} in ?name= evaluated at /api/v2/greet
# (finding: injection.possible_template_injection)
VULNERABLE_TEMPLATE=true
